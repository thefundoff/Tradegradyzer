# ──────────────────────────────────────────────────────────────
# TradeGradyzer environment variables
# Copy this file to `.env` and fill in your own values.
# Only VITE_* vars are exposed to the browser — never put secrets here.
# ──────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Name of the Supabase Edge Function that runs the Gemini analysis.
VITE_ANALYZE_FUNCTION=analyze-chart

# Set to "true" to bypass the real edge function and use a built-in
# mock analyzer (great for UI development without a Gemini key).
VITE_USE_MOCK_ANALYZER=true

# ──────────────────────────────────────────────────────────────
# The following are SERVER-SIDE secrets. They are NOT read by the
# frontend. Set them on the Supabase Edge Function instead:
#   supabase secrets set GEMINI_API_KEY=...
# ──────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash
#
# Password-reset emails (Resend) — used by the send-password-reset function:
#   supabase secrets set RESEND_API_KEY=re_...
#   supabase secrets set RESEND_FROM="TradeGradyzer <noreply@yourdomain.com>"
#   supabase secrets set SITE_URL=https://tradegradyzer.vercel.app
# Then add "${SITE_URL}/reset-password" to Supabase Auth → URL Configuration →
# Redirect URLs so the recovery link returns users to the app.
# RESEND_API_KEY=re_your-resend-api-key
# RESEND_FROM=TradeGradyzer <noreply@yourdomain.com>
# SITE_URL=https://tradegradyzer.vercel.app
